{
  "name": "platinum-place/php-dgii-xml-signer",
  "type": "library",
  "description": "Firmador XML para el uso del API de la DGII (Dirección General de Impuestos Internos) de República Dominicana",
  "keywords": [
    "DGII",
    "PHP",
    "XML",
    "e-CF",
    "signature",
    "xmldsig",
    "facturación-electrónica",
    "dominican-republic"
  ],
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "ext-dom": "*",
    "ext-openssl": "*",
    "selective/xmldsig": "^3.1"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "PlatinumPlace\\DgiiXmlSigner\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "PlatinumPlace\\DgiiXmlSigner\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "lint": "vendor/bin/php-cs-fixer fix",
    "analyze": "vendor/bin/phpstan analyze src --level=5"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}